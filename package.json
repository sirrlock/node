{
  "name": "@sirr/node",
  "version": "0.1.0",
  "description": "Sirr (سر) — Node.js client and npx CLI for the ephemeral secret vault",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SirrVault/node"
  },
  "main": "dist/index.js",
